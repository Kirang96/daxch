aws_region           = "ap-south-1"
environment          = "staging"
project_name         = "daxch"
domain_name          = "app.example.com"
route53_zone_id      = "Z123456ABCDEFG"
alb_acm_certificate_arn = "arn:aws:acm:ap-south-1:123456789012:certificate/alb-example"
cloudfront_acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/cloudfront-example"

backend_image        = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/daxch-backend:latest"
frontend_image       = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/daxch-frontend:latest"
worker_image         = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/daxch-worker:latest"
beat_image           = "123456789012.dkr.ecr.ap-south-1.amazonaws.com/daxch-beat:latest"

desired_count_frontend = 2
desired_count_backend  = 2
desired_count_worker   = 1
desired_count_beat     = 1

db_username = "daxch"
db_password = "replace-with-secret"
db_name     = "daxch"

backend_env_vars = {
  ENVIRONMENT         = "staging"
  DEBUG               = "false"
  ENABLE_DEMO_MODE    = "false"
  API_PREFIX          = "/api/v1"
  FRONTEND_BASE_URL   = "https://app.example.com"
  CORS_ORIGINS        = "https://app.example.com"
  AWS_REGION          = "ap-south-1"
  UPSTOX_REDIRECT_URI = "https://app.example.com/broker/callback"
}

app_secrets = {
  SECRET_KEY               = "replace-me"
  OPENAI_API_KEY           = "replace-me"
  UPSTOX_CLIENT_ID         = "replace-me"
  UPSTOX_CLIENT_SECRET     = "replace-me"
  RAZORPAY_KEY_ID          = "replace-me"
  RAZORPAY_KEY_SECRET      = "replace-me"
  RAZORPAY_WEBHOOK_SECRET  = "replace-me"
  RAZORPAY_PLAN_STARTER_ID = "plan_xxx"
  RAZORPAY_PLAN_PRO_ID     = "plan_yyy"
  RAZORPAY_PLAN_ULTRA_ID   = "plan_zzz"
  TAVILY_API_KEY           = "replace-me"
  NEWS_API_KEY             = "replace-me"
  SES_FROM_EMAIL           = "no-reply@example.com"
  FCM_CREDENTIALS_JSON     = "{\"type\":\"service_account\"}"
  FERNET_KEY               = "replace-me-base64-key"
}

